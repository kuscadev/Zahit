---
import { getLangFromUrl, useTranslations, getRouteFromUrl } from '../i18n/utils';
import { languages } from '../i18n/ui';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { SITE_CONFIG } from '../config';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const route = getRouteFromUrl(Astro.url);

// Fetch all posts to handle translation mapping
const allPosts: CollectionEntry<'blog'>[] = await getCollection('blog');
const isPost = route?.startsWith('blog/');
let currentTranslationKey: string | undefined = undefined;

if (isPost && route) {
	const currentSlug = route.replace('blog/', '').replace(/\/$/, '');
	const currentPost = allPosts.find(p => p.id === `${lang}/${currentSlug}`);
	if (currentPost) {
		currentTranslationKey = currentPost.data.translationKey;
	}
}
---
<header class="site-header">
	<nav>
		<div class="logo">
			<a href={`/${lang}/`}>{SITE_CONFIG.title}</a>
		</div>
		<div class="links">
			<a href={`/${lang}/`}>{t('nav.home')}</a>
			<a href={`/${lang}/archive/`}>{t('nav.archive')}</a>
			<a href={`/${lang}/about/`}>{t('nav.about')}</a>
		</div>
		<div class="lang-switcher">
			<ul>
				{Object.entries(languages).map(([abbr, label]) => {
					let targetRoute = route || '';
					
					if (targetRoute.startsWith('blog/') && lang !== abbr) {
						let matchedPost;
						if (currentTranslationKey) {
							matchedPost = allPosts.find(p => p.id.startsWith(`${abbr}/`) && p.data.translationKey === currentTranslationKey);
						}
						
						if (matchedPost) {
							const targetSlug = matchedPost.id.replace(`${abbr}/`, '');
							targetRoute = `blog/${targetSlug}/`;
						} else {
							targetRoute = 'archive/';
						}
					}
					
					return (
					<li>
						<a href={`/${abbr}${targetRoute ? `/${targetRoute}` : ''}`} class={lang === abbr ? 'active' : ''}>
							{abbr.toUpperCase()}
						</a>
					</li>
					);
				})}
			</ul>
		</div>
	</nav>
</header>

<style>
	.site-header {
		width: var(--site-width);
		padding: 2rem 0;
	}

	nav {
		display: flex;
		flex-wrap: wrap;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
	}

	.logo a {
		font-size: 1.5rem;
		font-weight: 700;
		color: #ffffff;
		letter-spacing: -0.02em;
	}
	
	.logo a:hover {
		color: var(--accent);
	}

	.links {
		display: flex;
		gap: 1.5rem;
	}

	.links a {
		font-size: 1rem;
		font-weight: 500;
		color: var(--light);
	}

	.links a:hover {
		color: #ffffff;
	}

	.lang-switcher ul {
		display: flex;
		gap: 0.5rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.lang-switcher a {
		font-size: 0.85rem;
		font-weight: 600;
		color: rgba(218, 234, 255, 0.5);
		padding: 0.2rem 0.4rem;
		border-radius: 4px;
	}

	.lang-switcher a:hover {
		color: #ffffff;
		background: rgba(255, 255, 255, 0.1);
	}

	.lang-switcher a.active {
		color: var(--bg-color);
		background: var(--light);
	}
</style>
